# Copy this to .env and fill in real values.
# Never commit .env.

# ─── OpenAI API key ────────────────────────────────────────────────────
# Used by the agent (tool planning, response formatting) and the L2 LLM judge.
OPENAI_API_KEY=

# ─── Service URLs ──────────────────────────────────────────────────────
# Defaults below work for local dev. Override for containers or remote setups.
SENTINEL_URL=http://127.0.0.1:8000/scan
VULNERABLE_MCP_URL=http://127.0.0.1:9001/mcp
TRUSTED_MCP_URL=http://127.0.0.1:9002/mcp
C2_SIMULATOR_URL=http://127.0.0.1:1337

# ─── Models ────────────────────────────────────────────────────────────
# AGENT_MODEL is the main agent LLM. JUDGE_MODEL is the L2 semantic classifier.
# JUDGE_MODEL should be smaller/cheaper since it runs on every suspicious input.
AGENT_MODEL=gpt-4o
JUDGE_MODEL=gpt-4o-mini
